# --- TAG-Patrolling environment configuration ---

# Server
PORT=4000
NODE_ENV=development

# App password gate (exact required password)
APP_PASSWORD=Tag%tpm$26

# Session
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_TIMEOUT_MINUTES=30

# Database (Prisma + SQLite)
DATABASE_URL="file:./dev.db"

# Client (Vite) - base URL of the API, used only in split dev mode
VITE_API_URL=http://localhost:4000

# Default global round tolerance (minutes), can be overridden per-plant in Plant Master
DEFAULT_ROUND_TOLERANCE_MINUTES=30
